# Copy this file to ".env" and fill in the real value.
# Get the service_role key from:
#   Supabase Dashboard -> Project Settings -> API -> Project API keys -> service_role (secret)
# WARNING: the service_role key bypasses Row Level Security. Keep it server-side only.
# Never expose it in any .html file or commit it to git.

SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional (the function already defaults to your project URL):
# SUPABASE_URL=https://gffqtqvdljtuttkrrzcb.supabase.co
